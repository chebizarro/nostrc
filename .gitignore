# Ignore build directories
build/
build*/
*/build*/
_build/
_build_asan/
Testing
tmp*/
out/
/bin/
/lib/
CMakeFiles/
CMakeCache.txt
Makefile
cmake_install.cmake
CTestTestfile.cmake
Testing
.cache/

# Ignore IDE and editor-specific files
.vscode/
/.idea/
/*.code-workspace
/.settings/
/*.sublime-project
/*.sublime-workspace
.clang-format
.editorconfig

# Ignore log files
*.log
*.temp

# Ignore compiled object files, static and shared libraries
*.o
*.obj
*.so
*.a
*.lib
*.dll
*.dylib
*.exe
*.mdb

# Ignore generated documentation files
/doxygen-docs/

# Ignore backup and temporary files created by editors or OS
*~
*.bak
*.swp
*.tmp
*.old
*.orig
*.rej
*.swo
*.DS_Store
/.AppleDouble
.LSOverride

# Ignore coverage and test result files
*.gcda
*.gcno
*.gcov

# Ignore CMake build artifacts
/cmake-build-*/  # For out-of-source CMake builds
/compile_commands.json
/*.dir
*.h.gch
/*.ipch
*.pch
g-ir-cpp-*.c

# Ignore CLion files (if used)
.idea/
cmake-build-*/
cmake-build/
**/cmake-build/

# Ignore Visual Studio build artifacts (if using MSVC)
*.VC.db
*.VC.VC.opendb

# Ignore Playwright test results
playwright-report/
node_modules/
package-lock.json

# Ignore bd (beads) local cache files
.beads/beads.db
.beads/last-touched

# Cargo/Rust build artifacts (libmarmot test vector generator)
libmarmot/tests/vectors/generator/target/
libmarmot/tests/vectors/generator/Cargo.lock

# In-source CMake build artifacts (generated by configure_file / codegen)
# These appear when CMake runs with source dir == build dir.
*.pc
!*.pc.in
*-version.h
!*-version.h.in
**/generated/nostr-config.h
**/resources.c
*.gresource
**/signer_proxy.c
**/signer_proxy.h
gschemas.compiled

# Compiled binaries (in-tree)
apps/gnostr/gnostr
apps/gnostr/gnostr-test-*

# Environment files with secrets
.env

# Gas Town (added by gt)
.runtime/
.claude/
.logs/
state.json

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
