# SPDX-License-Identifier: MIT
#
# Signet configuration (GKeyFile INI format)
#
# Required environment variables (Signet refuses to start without these):
#   SIGNET_DB_KEY       - Master key for SQLCipher (min 32 bytes, base64 or hex encoded)
#   SIGNET_BUNKER_NSEC  - Signet's own bunker identity nsec (bech32 or hex)
#
# All config values may be overridden by SIGNET_-prefixed environment variables.
# Lists use semicolons as separators (GKeyFile format).

[server]
log_level = info
health_port = 8080

[store]
# Path to SQLCipher database file
db_path = /data/signet.db
# Master key injected via env: SIGNET_DB_KEY (required, no default)
# Minimum 32 bytes of entropy, base64 or hex encoded

[nostr]
# Signet's own bunker identity
# Injected via env: SIGNET_BUNKER_NSEC (required, no default)

# Relay URLs (semicolon-separated)
relays = wss://relay.example.com

reconnect_interval_s = 30

# Pubkeys authorized to send management events (hex, semicolon-separated)
provisioner_pubkeys = aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Identity name for this bunker instance
identity = default

[policy_defaults]
default_decision = deny
# Path to policy JSON file (optional)
policy_file =
allowed_kinds =
rate_limit_rpm = 0

# Replay protection
[replay]
max_entries = 50000
ttl_seconds = 600
skew_seconds = 120

# Audit logging (structured JSON to stdout, 12-factor)
[audit]
path =
stdout = true